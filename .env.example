# URL base de tu AzuraCast (sin trailing slash)
AZURACASTURL=https://radio.kusmedios.lat

# API Key de AzuraCast
# Generala en: AzuraCast -> Mi Cuenta -> API Keys
AZURACASTAPIKEY=xxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Token para proteger el endpoint MCP (Bearer token)
# Si no lo defines, el endpoint es publico
MCPAPITOKEN=pon-aqui-un-token-secreto

# Puerto local (Fly.io lo inyecta automatico como 8080)
# PORT=8080
